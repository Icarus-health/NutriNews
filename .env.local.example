# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# AI Model fuer den News-Kurator-Agenten
# Mindestens EINEN der folgenden Keys setzen:

# Anthropic Claude (empfohlen - schnell, zuverlaessig)
# Key erstellen auf: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Hugging Face (kostenlos, aber weniger zuverlaessig)
# HUGGINGFACE_API_KEY=

# OpenAI (kostenpflichtig)
# OPENAI_API_KEY=

# Rate Limiting (optional, aber empfohlen fuer Produktion)
# Ohne diese Vars faellt die App auf einen In-Memory-Limiter zurueck,
# der pro Serverless-Instanz gilt und bei Cold-Starts zurueckgesetzt wird.
# Upstash Redis: https://console.upstash.com → Neue Datenbank → REST API Keys
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token

# Cron-Job Authentifizierung (nur fuer /api/news/cron benoetigt)
# CRON_SECRET=
